{
  "name": "ctrovalidate-react",
  "version": "1.0.0",
  "description": "React adapter for Ctrovalidate.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "homepage": "https://ctrovalidate.vercel.app/api/react",
  "keywords": [
    "ctrovalidate",
    "validation",
    "form-validation",
    "react",
    "hooks"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctrotech-tutor/ctrovalidate-react.git"
  },
  "bugs": {
    "url": "https://github.com/ctrotech-tutor/ctrovalidate-react/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "ctrovalidate-core": "^1.0.0",
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/react": "^18.2.0",
    "ctrovalidate-core": "^1.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.2.0",
    "prettier": "^3.1.1",
    "react": "^18.2.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
