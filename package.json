{
  "name": "ctrovalidate-react",
  "version": "1.0.0",
  "description": "React adapter for Ctrovalidate.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.build.json",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "ctrovalidate-core": "^1.0.0",
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "ctrovalidate-core": "^1.0.0",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.5.1",
    "vitest": "^4.0.18",
    "eslint": "^9.39.2",
    "@eslint/js": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "prettier": "^3.1.1",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.2.0"
  }
}
